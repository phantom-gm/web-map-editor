# 웹 맵 에디터 백엔드(/api) 환경변수. Vercel 프로젝트 Settings → Environment Variables 에 설정.
# 로컬은 .env.local 로 복사(.gitignore 됨).

# msw-mcp HTTP MCP 서버(asset 도구). 토큰은 .mcp.json 의 Authorization 값.
MSW_MCP_URL=https://msw-mcp.nexon.com/mcp
MSW_MCP_TOKEN=Bearer <your-token>
MSW_GROUP_CODE=43bIK

# /api 공유 시크릿. 클라이언트가 x-editor-secret 헤더로 전송. 충분히 긴 랜덤 문자열로.
EDITOR_SHARED_SECRET=change-me-to-a-long-random-string

# (선택) Vercel KV / Upstash Redis REST — 있으면 레지스트리 영속/업로드 append.
# 없으면 메모리(시드 data/registry.seed.json) — 업로드 append 가 프로세스 내에서만 유지.
KV_REST_API_URL=
KV_REST_API_TOKEN=
